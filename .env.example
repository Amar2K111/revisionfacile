# Copier vers .env.local et remplir les valeurs.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
GEMINI_API_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
# Clé secrète (sk_test_… ou sk_live_…), jamais exposée au navigateur.
STRIPE_SECRET_KEY=
# Clé publique (pk_test_… ou pk_live_…), OK pour le client.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Signing secret du webhook (whsec_…), un par endpoint dans le dashboard.
STRIPE_WEBHOOK_SECRET=

# Activer le portail client (abonnement / factures) : Dashboard Stripe → Paramètres → Facturation → Portail client
# Les redirections reviennent sur /reviser, /fiche ou /paywall selon la page d’origine.

# URL publique du site (optionnel, pour les redirections Stripe en prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — clé service (Dashboard → Settings → API) : uniquement serveur, pour le webhook Stripe.
SUPABASE_SERVICE_ROLE_KEY=

# --- Edge Function `stripe-webhook` (optionnel : même logique que app/api/stripe/webhook)
# En prod, endpoint Stripe recommandé :
#   https://<PROJECT_REF>.supabase.co/functions/v1/stripe-webhook
# Dashboard → Edge Functions → Secrets (ou CLI : seulement Stripe, ex. `supabase secrets set STRIPE_SECRET_KEY=... STRIPE_WEBHOOK_SECRET=...` — un fichier avec `SUPABASE_*` verra ces lignes ignorées : c’est voulu).
#   STRIPE_SECRET_KEY        (même valeur que ci‑dessus)
#   STRIPE_WEBHOOK_SECRET    (whsec_… du endpoint qui pointe vers l’URL Edge ci‑dessus)
# SUPABASE_URL et SUPABASE_SERVICE_ROLE_KEY sont fournis automatiquement sur l’hébergement Supabase (ne pas les passer via `secrets set`).
# Voir supabase/functions/.env.example pour le dev local (supabase functions serve --no-verify-jwt).

# Stripe — prix récurrent (optionnel si tu utilises les montants EUR ci‑dessous : Checkout crée le prix à la volée)
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
# Rétrocompat : si MONTHLY absent, STRIPE_PREMIUM_PRICE_ID est utilisé comme prix mensuel
# STRIPE_PREMIUM_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=

# Montants serveur (optionnel) — prioritaire sur NEXT_PUBLIC_* pour le checkout sans price_id
# STRIPE_PREMIUM_MONTHLY_EUR=9.99
# STRIPE_PREMIUM_YEARLY_EUR=29.99

# Libellés paywall (alignés Stripe)
NEXT_PUBLIC_PREMIUM_PRICE_LABEL=9,99 €
NEXT_PUBLIC_PREMIUM_YEARLY_PRICE_LABEL=29,99 €

# Montants EURO (chiffres) : paywall + checkout sans price_id (défauts 9.99 / 29.99)
NEXT_PUBLIC_PREMIUM_MONTHLY_EUR=9.99
NEXT_PUBLIC_PREMIUM_YEARLY_EUR=29.99

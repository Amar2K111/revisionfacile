# Copier vers supabase/functions/.env pour `supabase functions serve stripe-webhook --no-verify-jwt`
# Ne pas committer le fichier .env rempli.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Dev local uniquement : ajoute SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (même projet que .env.local).
# Ces deux noms ne peuvent PAS être poussés avec `supabase secrets set` (réservés par la plateforme) — ignorés avec message « skipping » : normal.

